{
  "name": "aria-api",
  "source": {
    "type": "dockerfile",
    "dockerfile": "infra/docker/Dockerfile.api.prod"
  },
  "deploy": {
    "healthcheckPath": "/health",
    "startCommand": "alembic upgrade head && uvicorn backend.api.main:app --host 0.0.0.0 --port $PORT --workers 2"
  },
  "variables": {
    "PORT": "8000",
    "ARIA_ENV": "production",
    "LOG_LEVEL": "INFO"
  }
}
